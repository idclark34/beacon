# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here

# Optional — admin key for spend tracking (cost API requires admin scope).
# Falls back to ANTHROPIC_API_KEY if blank; 401/403 responses are handled gracefully.
ANTHROPIC_ADMIN_KEY=

# Your monthly Anthropic spend limit in USD. Leave blank to disable spend tracking.
ANTHROPIC_MONTHLY_BUDGET=25
